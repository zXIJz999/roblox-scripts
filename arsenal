local BONE_PAIRS={
  {"Head","UpperTorso"},{"UpperTorso","LowerTorso"},
  {"UpperTorso","LeftUpperArm"},{"LeftUpperArm","LeftLowerArm"},{"LeftLowerArm","LeftHand"},
  {"UpperTorso","RightUpperArm"},{"RightUpperArm","RightLowerArm"},{"RightLowerArm","RightHand"},
  {"LowerTorso","LeftUpperLeg"},{"LeftUpperLeg","LeftLowerLeg"},{"LeftLowerLeg","LeftFoot"},
  {"LowerTorso","RightUpperLeg"},{"RightUpperLeg","RightLowerLeg"},{"RightLowerLeg","RightFoot"},
}

local espPool={}
local function getESPEntry(plr)
  if espPool[plr] then return espPool[plr] end
  local e={
    lines={}, nameText=newText(12,CFG.esp_name_col),
    hpText=newText(11,CFG.esp_hp_col), distText=newText(10,Color3.fromRGB(160,120,220)),
    snapLine=newLine(CFG.snap_thick,CFG.snap_col), skelLines={}, selBoxes={},
    hpBarBg=newLine(3, Color3.new(0,0,0)), hpBarFill=newLine(1, Color3.new(0,1,0))
  }
  for i=1,4 do e.lines[i]=newLine(CFG.esp_thick,CFG.esp_box_col) end
  for i=1,#BONE_PAIRS do e.skelLines[i]=newLine(CFG.esp_skel_thick,CFG.esp_skel_col) end
  espPool[plr]=e; return e
end

local function hideESP(e)
  for _,l in ipairs(e.lines) do l.Visible=false end
  for _,l in ipairs(e.skelLines) do l.Visible=false end
  e.nameText.Visible=false; e.hpText.Visible=false
  e.distText.Visible=false; e.snapLine.Visible=false
  e.hpBarBg.Visible=false; e.hpBarFill.Visible=false
end

local function cleanESP(plr)
  if not espPool[plr] then return end
  hideESP(espPool[plr])
  for _,sb in pairs(espPool[plr].selBoxes) do
    if sb and sb.Parent then sb:Destroy() end
  end
  espPool[plr]=nil
end
Players.PlayerRemoving:Connect(cleanESP)

local function getCharBox(char)
  local root=char:FindFirstChild("HumanoidRootPart")
  if not root then return nil end
  local hum=char:FindFirstChildOfClass("Humanoid")
  local topPos=root.Position+V3(0,3.2,0)
  local botPos=root.Position-V3(0,3.0,0)
  local sp,onScreen=Camera:WorldToViewportPoint(root.Position)
  if not onScreen or sp.Z<0 then return nil end
  local top2d,onT=Camera:WorldToViewportPoint(topPos)
  local bot2d,onB=Camera:WorldToViewportPoint(botPos)
  if not onT or not onB then return nil end
  local boxH=math.abs(top2d.Y-bot2d.Y)
  if boxH<4 then return nil end
  local boxW=boxH*0.5
  local cx=sp.X
  local ty=top2d.Y; local by_=bot2d.Y
  local hp=hum and hum.Health or 0
  local maxhp=hum and hum.MaxHealth or 100
  return {
    tl=V2(cx-boxW*0.5,ty), tr=V2(cx+boxW*0.5,ty),
    bl=V2(cx-boxW*0.5,by_), br=V2(cx+boxW*0.5,by_),
    cx=cx, hpPct=mcl(hp/math.max(maxhp,1),0,1), hp=mfl(hp),
    bot=V2(cx,by_),
    dist=mfl((root.Position-Camera.CFrame.Position).Magnitude),
  }
end

local function drawSkeleton(char,skelLines)
  local isR15=char:FindFirstChild("UpperTorso")~=nil
  local first=isR15 and 1 or 15; local last=isR15 and 14 or 19
  for i=1,#BONE_PAIRS do skelLines[i].Visible=false end
  if not CFG.esp_skel_on then return end
  for i=first,last do
    local pair=BONE_PAIRS[i]
    local pA=char:FindFirstChild(pair[1])
    local pB=char:FindFirstChild(pair[2])
    if pA and pB then
      local a2,onA=Camera:WorldToViewportPoint(pA.Position)
      local b2,onB=Camera:WorldToViewportPoint(pB.Position)
      if onA and onB and a2.Z>0 and b2.Z>0 then
        local sl=skelLines[i]
        sl.From=V2(a2.X,a2.Y); sl.To=V2(b2.X,b2.Y)
        sl.Color=CFG.esp_skel_col; sl.Visible=true
      end
    end
  end
end

