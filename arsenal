local function createTracer(origin, target)
    if not CFG.tracers_on then return end
    local tracer = Drawing.new("Line")
    tracer.Visible = true; tracer.Color = CFG.tracers_col; tracer.Thickness = 2; tracer.Transparency = 1
    local spO, onO = Camera:WorldToViewportPoint(origin)
    local spT, onT = Camera:WorldToViewportPoint(target)
    if onO and onT then
        tracer.From = V2(spO.X, spO.Y); tracer.To = V2(spT.X, spT.Y)
        task.spawn(function() for i = 1, 0, -0.1 do tracer.Transparency = i; task.wait(0.02) end; tracer:Remove() end)
    else tracer:Remove() end
end

local saHookInstalled = false
local oldNamecall = nil

task.defer(function()
    if saHookInstalled then return end
    if not hookmetamethod then return end
    
    oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
        local method = getnamecallmethod()
        local args = {...}
        
        if CFG.sa_on and not checkcaller() and mra(1,100) <= CFG.sa_hitpct then
            local pn = mra(1,100) <= CFG.sa_headpct and "Head" or "Torso"
            local pos = getTarget(CFG.sa_fov, CFG.sa_predmult, pn)
            
            if pos then
                if method == "Raycast" then
                    args[2] = (pos - args[1]).Unit * args[2].Magnitude
                    createTracer(args[1], pos); playHitSound()
                    return oldNamecall(self, unpack(args))
                elseif method == "FindPartOnRayWithIgnoreList" or method == "FindPartOnRay" then
                    local origin = args[1].Origin
                    args[1] = Ray.new(origin, (pos - origin).Unit * args[1].Direction.Magnitude)
                    createTracer(origin, pos); playHitSound()
                    return oldNamecall(self, unpack(args))
                elseif method == "FireServer" and tostring(self) == "HitPart" then
                    local targetChar = getTargetChar(CFG.sa_fov)
                    if targetChar and targetChar:FindFirstChild(pn) then args[1] = targetChar[pn] end
                    return oldNamecall(self, unpack(args))
                end
            end
        end
        return oldNamecall(self, ...)
    end)
    saHookInstalled = true
end)

