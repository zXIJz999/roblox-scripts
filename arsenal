-- SILENT AIM HOOK
-- ═══════════════════════════════════════════════════════════
local saHookInstalled=false
local oldNamecall=nil
if hookmetamethod then
    local ok,err=pcall(function()
        oldNamecall=hookmetamethod(game,"__namecall",function(self,...)
            local method=getnamecallmethod()
            local args={...}
            if CFG.sa_on and not checkcaller() and mra(1,100)<=CFG.sa_hitpct then
                local pn=mra(1,100)<=CFG.sa_headpct and "Head" or "UpperTorso"
                local pos=getTarget(CFG.sa_fov,CFG.sa_predmult,pn)
                if pos then
                    if method=="Raycast" and self==workspace then
                        local origin=args[1]
                        if typeof(origin)=="Vector3" and typeof(args[2])=="Vector3" then
                            args[2]=(pos-origin).Unit*args[2].Magnitude
                            playHitSound()
                            return oldNamecall(self,table.unpack(args))
                        end
                    elseif (method=="FindPartOnRayWithIgnoreList" or method=="FindPartOnRay") and self==workspace then
                        local ray2=args[1]
                        if typeof(ray2)=="Ray" then
                            args[1]=Ray.new(ray2.Origin,(pos-ray2.Origin).Unit*ray2.Direction.Magnitude)
                            playHitSound()
                            return oldNamecall(self,table.unpack(args))
                        end
                    elseif method=="FireServer" then
                        -- Ammo reserve hook: if ammo_reserve_on, intercept shoot remotes
                        -- and swap ammo source field so server uses reserve count
                        if CFG.ammo_reserve_on then
                            local remoteName=tostring(self.Name or self)
                            if remoteName:lower():find("shoot") or remoteName:lower():find("fire") or remoteName:lower():find("bullet") then
                                if type(args[1])=="table" then
                                    -- Arsenal bullet data: try to set ammo field to reserve
                                    if args[1].ammo ~= nil then args[1].ammo = 999 end
                                    if args[1].reserve ~= nil then args[1].reserve = 999 end
                                    if args[1].mag ~= nil then args[1].mag = 999 end
                                end
                            end
                        end
                        -- Silent aim FireServer
                        if CFG.sa_on then
                            local tPlr=getTargetPlayer(CFG.sa_fov)
                            if tPlr and tPlr.Character then
                                local targetPart=tPlr.Character:FindFirstChild(pn)
                                if targetPart then
                                    args[1]=targetPart
                                    playHitSound()
                                    return oldNamecall(self,table.unpack(args))
                                end
                            end
                        end
                    end
                end
            elseif CFG.ammo_reserve_on and not checkcaller() and method=="FireServer" then
                -- Catch ammo reserve even when SA is off
                local remoteName=tostring(self.Name or self)
                if remoteName:lower():find("shoot") or remoteName:lower():find("fire") or remoteName:lower():find("bullet") then
                    if type(args[1])=="table" then
                        if args[1].ammo ~= nil then args[1].ammo = 999 end
                        if args[1].reserve ~= nil then args[1].reserve = 999 end
                        if args[1].mag ~= nil then args[1].mag = 999 end
                        return oldNamecall(self,table.unpack(args))
                    end
                end
            end
            return oldNamecall(self,...)
        end)
        saHookInstalled=true; dbg("SA","hookmetamethod installed OK")
    end)
    if not ok then dbgErr("SA","hookmetamethod failed: "..tostring(err)) end
else
    dbg("SA","hookmetamethod not available")
end

