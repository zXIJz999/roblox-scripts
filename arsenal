    tickAimbot(dt)
    tickTriggerbot()
    tickHitmarker(dt, cx, cy)
    tickDamageNumbers(dt)

    -- Crosshair
    chAngle = chAngle + CFG.ch_rot_speed*dt
    chHue   = (chHue + CFG.ch_hue_speed*dt) % 1
    local col = Color3.fromHSV(chHue,1,1); local S = CFG.ch_size; local li = 1
    for _, seg in ipairs(SW_SEGS) do
        local ax,ay = rot2(seg[1]*S,seg[2]*S,chAngle)
        local bx,by = rot2(seg[3]*S,seg[4]*S,chAngle)
        CH_LINES[li].From=sv(ax,ay,cx,cy); CH_LINES[li].To=sv(bx,by,cx,cy)
        CH_LINES[li].Color=col; CH_LINES[li].Visible=CFG.ch_on; li=li+1
        local lax,lay = rot2(seg[5]*S,seg[6]*S,chAngle)
        local lbx,lby = rot2(seg[7]*S,seg[8]*S,chAngle)
        CH_LINES[li].From=sv(lax,lay,cx,cy); CH_LINES[li].To=sv(lbx,lby,cx,cy)
        CH_LINES[li].Color=col; CH_LINES[li].Visible=CFG.ch_on; li=li+1
    end

    -- Keybinds UI (throttled)
    updateKeybindsUI()
end)
