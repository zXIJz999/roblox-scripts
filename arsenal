-- ESP BOX — FOV FIXED:
-- Width is derived from world-space shoulder projection using CURRENT camera FOV
-- so it scales correctly whether fov_on is true or false
local function getCharBox(char)
    local root=char:FindFirstChild("HumanoidRootPart"); local head=char:FindFirstChild("Head")
    if not root or not head then return nil end
    local hum=char:FindFirstChildOfClass("Humanoid")
    local hrp2d,onScreen=Camera:WorldToViewportPoint(root.Position)
    if not onScreen or hrp2d.Z<0 then return nil end

    -- Use actual top of head and bottom of feet — projected using current FOV
    local topPos=head.Position+V3(0,head.Size.Y*0.5,0)
    -- Bottom: get the lowest visible part (foot or HRP -3)
    local leftFoot=char:FindFirstChild("LeftFoot") or char:FindFirstChild("Left Leg")
    local rightFoot=char:FindFirstChild("RightFoot") or char:FindFirstChild("Right Leg")
    local botPos
    if leftFoot and rightFoot then
        local ly=leftFoot.Position.Y; local ry=rightFoot.Position.Y
        local lowestY=math.min(ly,ry)-0.5
        botPos=V3(root.Position.X,lowestY,root.Position.Z)
    else
        botPos=root.Position-V3(0,3,0)
    end

    local top2d,onT=Camera:WorldToViewportPoint(topPos)
    local bot2d,onB=Camera:WorldToViewportPoint(botPos)
    if not onT or not onB or top2d.Z<0 or bot2d.Z<0 then return nil end
    local boxH=math.abs(bot2d.Y-top2d.Y); if boxH<4 then return nil end

    -- World-space width: project left and right shoulder using actual camera
    -- This automatically accounts for current FOV
    local sL=Camera:WorldToViewportPoint(root.Position-root.CFrame.RightVector*1.5)
    local sR=Camera:WorldToViewportPoint(root.Position+root.CFrame.RightVector*1.5)
    local boxW=math.max(math.abs(sR.X-sL.X), boxH*0.35)

    local hp=hum and hum.Health or 0; local maxhp=hum and hum.MaxHealth or 100
    local cx2=hrp2d.X
    return {
        tl=V2(cx2-boxW*0.5,top2d.Y), tr=V2(cx2+boxW*0.5,top2d.Y),
        bl=V2(cx2-boxW*0.5,bot2d.Y), br=V2(cx2+boxW*0.5,bot2d.Y),
        cx=cx2, hpPct=mcl(hp/math.max(maxhp,1),0,1),
        hp=mfl(hp), bot=V2(cx2,bot2d.Y), dist=mfl(hrp2d.Z),
    }
end

local function drawSkeleton(char,skelLines)
    for i=1,#BONE_PAIRS do skelLines[i].Visible=false end
    if not CFG.esp_skel_on then return end
    for i=1,#BONE_PAIRS do
        local pair=BONE_PAIRS[i]
        local pA=char:FindFirstChild(pair[1]); local pB=char:FindFirstChild(pair[2])
        if pA and pB then
            local a2,onA=Camera:WorldToViewportPoint(pA.Position)
            local b2,onB=Camera:WorldToViewportPoint(pB.Position)
            if onA and onB and a2.Z>0 and b2.Z>0 then
                local sl=skelLines[i]; sl.From=V2(a2.X,a2.Y); sl.To=V2(b2.X,b2.Y)
                sl.Color=CFG.esp_skel_col; sl.Visible=true
            end
        end
    end
end

