-- ═══════════════════════════════════════════════════════════
local dmgPool = {}

local function spawnDamageNumber(worldPos, amount, isHead)
    if not CFG.damage_numbers_on then return end
    local t = Drawing.new("Text")
    t.Text = (isHead and "!" or "") .. tostring(mfl(amount))
    t.Size = isHead and 16 or 13
    t.Font = Drawing.Fonts.UI
    t.Color = isHead and CFG.dmg_col_head or CFG.dmg_col_normal
    t.Outline = true; t.OutlineColor = Color3.new(0,0,0)
    t.Visible = true; t.ZIndex = 998
    table.insert(dmgPool, {text=t, worldPos=worldPos, alpha=1, offsetY=0, life=0, maxLife=1.2})
end

local function tickDamageNumbers(dt)
    for i = #dmgPool, 1, -1 do
        local d = dmgPool[i]
        d.life = d.life + dt
        d.offsetY = d.offsetY - 28*dt
        d.alpha = 1 - (d.life / d.maxLife)
        if d.alpha <= 0 then
            pcall(function() d.text:Remove() end)
            table.remove(dmgPool, i)
        else
            local sp, on = Camera:WorldToViewportPoint(d.worldPos + V3(0, d.offsetY*0.1, 0))
            if on and sp.Z > 0 then
                d.text.Position = V2(sp.X - 12, sp.Y + d.offsetY)
                d.text.Transparency = d.alpha; d.text.Visible = true
            else
                d.text.Visible = false
            end
        end
    end
end

