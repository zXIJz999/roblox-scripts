GB.CfgSave:AddLabel('Menu Toggle Key'):AddKeyPicker('kb_menu',{Default='RightShift',NoUI=true,Text='Menu Keybind'})
Library.ToggleKeybind=Options.kb_menu
GB.CfgSave:AddButton('Save Config',function()
    if not writefile then return end; initFolders()
    local t={}
    for k,v in pairs(CFG) do if type(v)~="userdata" and type(v)~="function" then t[k]=v end end
    pcall(function() writefile(cfgFilePath,HttpService:JSONEncode(t)) end)
    Library:Notify("Config Saved!")
end)
GB.CfgSave:AddButton('Load Config',function()
    if not readfile then return end
    pcall(function()
        local t=HttpService:JSONDecode(readfile(cfgFilePath))
        for k,v in pairs(t) do if CFG[k]~=nil and type(CFG[k])==type(v) then CFG[k]=v end end
    end)
    Library:Notify("Config Loaded!")
end)
GB.CfgSave:AddToggle('auto_load',{Text='Auto-Load Config on Boot',Default=false})
Toggles.auto_load:OnChanged(function()
    if writefile then initFolders(); pcall(function() writefile(autoLoadPath,tostring(Toggles.auto_load.Value)) end) end
end)
if readfile then
    pcall(function()
        if readfile(autoLoadPath)=="true" then
            local t=HttpService:JSONDecode(readfile(cfgFilePath))
            for k,v in pairs(t) do if CFG[k]~=nil and type(CFG[k])==type(v) then CFG[k]=v end end
            Toggles.auto_load:SetValue(true); Library:Notify("Auto-Loaded Config!")
        end
    end)
end

