local myGunFireLine=nil
local myGunLineFade=0
local lastShotTarget=nil

local function recordShot()
    local ray=Camera:ScreenPointToRay(Camera.ViewportSize.X/2,Camera.ViewportSize.Y/2)
    local params=RaycastParams.new()
    params.FilterDescendantsInstances={LP.Character}
    params.FilterType=Enum.RaycastFilterType.Exclude
    local result=workspace:Raycast(ray.Origin,ray.Direction*1000,params)
    lastShotTarget=result and result.Position or (ray.Origin+ray.Direction*500)
    myGunLineFade=1
end

UIS.InputBegan:Connect(function(inp,gp)
    if gp then return end
    if inp.UserInputType==Enum.UserInputType.MouseButton1 then
        if CFG.tracer_mode=="mygun" or CFG.tracer_mode=="all" then recordShot() end
    end
end)

local function tickVisualTracers(dt,cx,screenH)
    if (CFG.tracer_mode=="mygun" or CFG.tracer_mode=="all") and myGunLineFade>0 and lastShotTarget then
        myGunLineFade=myGunLineFade-dt*3
        if not myGunFireLine then
            myGunFireLine=Drawing.new("Line"); myGunFireLine.ZIndex=10
        end
        local spT,onT=Camera:WorldToViewportPoint(lastShotTarget)
        if onT and spT.Z>0 then
            myGunFireLine.From=V2(cx,screenH); myGunFireLine.To=V2(spT.X,spT.Y)
            myGunFireLine.Color=CFG.tracer_my_col; myGunFireLine.Thickness=CFG.tracer_thickness
            myGunFireLine.Transparency=math.max(myGunLineFade,0); myGunFireLine.Visible=true
        else myGunFireLine.Visible=false end
    else
        if myGunFireLine then myGunFireLine.Visible=false end
    end
end

