-- AIMBOT & RAGE (STRAFE + KILL ALL)
-- ═══════════════════════════════════════════════════════════
local strafeAngle = 0

local function tickAimbot(dt)
  -- RAGE KILL ALL (Teleports behind enemies sequentially)
  if CFG.rage_kill_all and LP.Character and LP.Character:FindFirstChild("HumanoidRootPart") then
      local target = getTarget(9999, 0, "HumanoidRootPart")
      if target then
          LP.Character.HumanoidRootPart.CFrame = CFrame.new(target + Vector3.new(0, 0, 4), target)
          mouse:Button1Click() -- Auto swing/shoot
      end
  end

  if not CFG.ab_on and not CFG.rage_strafe_on then return end
  if CFG.ab_hold_key and not UIS:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) and not CFG.rage_strafe_on then return end
  if not LP.Character then return end
  local pos=getTarget(CFG.ab_fov,CFG.ab_predmult,CFG.ab_part)
  if not pos then return end
  
  -- RAGE STRAFE (Teleport around target while locked on)
  if CFG.rage_strafe_on and UIS:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) and LP.Character:FindFirstChild("HumanoidRootPart") then
      strafeAngle = strafeAngle + CFG.rage_strafe_speed * dt
      local offset = Vector3.new(math.cos(strafeAngle) * CFG.rage_strafe_range, math.sin(strafeAngle * 1.5) * (CFG.rage_strafe_range/2), math.sin(strafeAngle) * CFG.rage_strafe_range)
      LP.Character.HumanoidRootPart.CFrame = CFrame.new(pos + offset, pos)
  end

  local jx,jy=0,0
  if CFG.ab_jitter then
    local m=CFG.ab_jitter_mag; jx=(mra()*2-1)*m*0.01; jy=(mra()*2-1)*m*0.01
  end
  local camPos=Camera.CFrame.Position
  local targetCF=CF(camPos,pos+V3(jx,jy,0))
  
  -- Hard Lock skips smoothing
  if CFG.ab_hard_lock then
      Camera.CFrame = targetCF
      return
  end
  
  if not CFG.ab_axis_x or not CFG.ab_axis_y then
    local curCF=Camera.CFrame
    local tx,ty,tz=targetCF:ToEulerAnglesYXZ(); local cx,cy,_=curCF:ToEulerAnglesYXZ()
    if not CFG.ab_axis_x then ty=cy end
    if not CFG.ab_axis_y then tx=cx end
    targetCF=CF(camPos)*CFrame.fromEulerAnglesYXZ(tx,ty,tz)
  end
  local maxRad=math.rad(CFG.ab_max_speed)*dt
  local curCF=Camera.CFrame
  local angle=math.acos(mcl(curCF.LookVector:Dot(targetCF.LookVector),-1,1))
  local lerpT=CFG.ab_smooth
  if angle>maxRad then lerpT=mcl(maxRad/angle,0,lerpT) end
  Camera.CFrame=curCF:Lerp(targetCF,lerpT)
end

