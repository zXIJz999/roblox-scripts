-- STRAFE HELPERS
-- ═══════════════════════════════════════════════════════════
local strafeAngle = 0

local function isPosSafe(pos)
    if pos.Y < CFG.rage_min_y then return false end
    local result = workspace:Raycast(pos + V3(0,50,0), V3(0,-100,0))
    return result ~= nil
end

local function getStrafePos(tHrpPos)
    local r = CFG.rage_strafe_range
    local offset = V3(mco(strafeAngle)*r, math.abs(msi(strafeAngle*1.5))*(r*0.4), msi(strafeAngle)*r)
    local newPos = tHrpPos + offset
    local gr = workspace:Raycast(newPos + V3(0,10,0), V3(0,-20,0))
    if gr then newPos = V3(newPos.X, math.max(newPos.Y, gr.Position.Y + 3), newPos.Z) end
    return newPos
end

-- ═══════════════════════════════════════════════════════════
-- AIMBOT & RAGE
-- ═══════════════════════════════════════════════════════════
local lockedKaTarget = nil

local function doShoot()
    if mouse1click then mouse1click()
    else mouse:Button1Down(); task.wait(0.013); mouse:Button1Up() end
end

local function tickAimbot(dt)
    -- KILL ALL
    if CFG.rage_kill_all and LP.Character and LP.Character:FindFirstChild("HumanoidRootPart") then
        local ka = lockedKaTarget
        if not ka or not ka.Character
            or not ka.Character:FindFirstChildOfClass("Humanoid")
            or ka.Character.Humanoid.Health <= 0 then
            lockedKaTarget = getSafestTarget(); ka = lockedKaTarget
        end
        if ka and ka.Character then
            local tHrp  = ka.Character:FindFirstChild("HumanoidRootPart")
            local tHead = ka.Character:FindFirstChild("Head")
            if tHrp and tHead then
                if not isPosSafe(tHrp.Position) then
                    lockedKaTarget = nil
                else
                    strafeAngle = strafeAngle + CFG.rage_strafe_speed * dt
                    local newPos = getStrafePos(tHrp.Position)
                    if isPosSafe(newPos) then
                        LP.Character.HumanoidRootPart.CFrame = CFrame.new(newPos, tHead.Position)
                        Camera.CFrame = CFrame.new(newPos, tHead.Position)
                        if CFG.rage_auto_shoot then doShoot() end
                        return
                    end
                end
            end
        end
    else
        lockedKaTarget = nil
    end

    -- MANUAL STRAFE (hold key)
    if Options.kb_strafe:GetState() and LP.Character and LP.Character:FindFirstChild("HumanoidRootPart") then
        local tgt = getSafestTarget()
        if tgt and tgt.Character then
            local tHrp  = tgt.Character:FindFirstChild("HumanoidRootPart")
            local tHead = tgt.Character:FindFirstChild("Head")
            if tHrp and tHead and isPosSafe(tHrp.Position) then
                strafeAngle = strafeAngle + CFG.rage_strafe_speed * dt
                local newPos = getStrafePos(tHrp.Position)
                if isPosSafe(newPos) then
                    LP.Character.HumanoidRootPart.CFrame = CFrame.new(newPos, tHead.Position)
                    Camera.CFrame = CFrame.new(newPos, tHead.Position)
                    if CFG.rage_auto_shoot then doShoot() end
                    return
                end
            end
        end
    end

    -- STANDARD AIMBOT
    if not CFG.ab_on then return end
    if CFG.ab_hold_key and not UIS:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then return end
    if not LP.Character then return end
    local pos = getTarget(CFG.ab_fov, CFG.ab_predmult, CFG.ab_part)
    if not pos then return end
    local targetCF = CFrame.new(Camera.CFrame.Position, pos)
    if CFG.ab_hard_lock then Camera.CFrame = targetCF; return end
    local maxRad = math.rad(CFG.ab_max_speed) * dt
    local angle  = math.acos(mcl(Camera.CFrame.LookVector:Dot(targetCF.LookVector), -1, 1))
    local lerpT  = CFG.ab_smooth
    if angle > maxRad then lerpT = mcl(maxRad/angle, 0, lerpT) end
    Camera.CFrame = Camera.CFrame:Lerp(targetCF, lerpT)
end

