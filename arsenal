local HM_LINES = {}
for i = 1, 4 do
    local l = Drawing.new("Line")
    l.Thickness = 1.5; l.Color = Color3.fromRGB(255,255,255)
    l.Visible = false; l.ZIndex = 999
    HM_LINES[i] = l
end
local hmAlpha = 0; local hmActive = false; local hmIsHead = false

local sndHitmarker = Instance.new("Sound")
sndHitmarker.SoundId = "rbxassetid://4612430935"
sndHitmarker.Volume = 0.8
pcall(function() sndHitmarker.Parent = CoreGui end)

local function showHitmarker(isHead)
    if not CFG.hitmarker_on then return end
    hmActive = true; hmAlpha = 1; hmIsHead = isHead
    if CFG.hitmarker_sound_on then sndHitmarker:Stop(); sndHitmarker:Play() end
end

local function tickHitmarker(dt, cx, cy)
    if not hmActive then
        for _, l in ipairs(HM_LINES) do l.Visible = false end; return
    end
    hmAlpha = hmAlpha - dt / math.max(CFG.hitmarker_duration, 0.01)
    if hmAlpha <= 0 then
        hmActive = false
        for _, l in ipairs(HM_LINES) do l.Visible = false end; return
    end
    local col = hmIsHead and Color3.fromRGB(255,80,80) or CFG.hitmarker_col
    local s = CFG.hitmarker_size; local gap = s * 0.4
    local dirs = {{-1,-1},{1,-1},{1,1},{-1,1}}
    for i, d in ipairs(dirs) do
        local l = HM_LINES[i]
        l.From = V2(cx + d[1]*gap, cy + d[2]*gap)
        l.To   = V2(cx + d[1]*s,   cy + d[2]*s)
        l.Color = col; l.Transparency = hmAlpha; l.Visible = true
    end
end

