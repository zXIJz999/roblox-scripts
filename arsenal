-- ═══════════════════════════════════════════════════════════
local lastCamCF = nil
RunService.RenderStepped:Connect(function()
    if not CFG.no_recoil_on then lastCamCF = Camera.CFrame; return end
    if lastCamCF then
        local lastPitch = math.asin(mcl(lastCamCF.LookVector.Y, -1, 1))
        local curPitch  = math.asin(mcl(Camera.CFrame.LookVector.Y, -1, 1))
        local delta     = curPitch - lastPitch
        if delta > 0.004 then
            local comp = delta * (1 - CFG.recoil_strength)
            Camera.CFrame = Camera.CFrame * CFrame.fromEulerAnglesYXZ(-comp, 0, 0)
        end
    end
    lastCamCF = Camera.CFrame
end)

