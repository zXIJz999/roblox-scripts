-- SILENT AIM (Arsenal pfNetwork hook)
-- ═══════════════════════════════════════════════════════════
local pfNetwork=nil; local pfBullet=nil; local pfPubSettings=nil
local pfHooked=false; local origSend=nil; local origNewBullet=nil
local saRoll=100; local saHead=0

task.spawn(function() while true do task.wait(0.08); saRoll=mra(1,100); saHead=mra(1,100) end end)

local function solveVel(origin,accel,target,speed)
  local f=-accel; local ld=target-origin; local a=f:Dot(f)
  if a==0 then return (target-origin).Unit*speed end
  local k=(4*(f:Dot(ld)+speed*speed))/(2*a)
  local disc=math.max(0,k*k-(4*(ld:Dot(ld)))/a)
  local sq=disc^0.5; local t1,t2=k-sq,k+sq
  local t=(t1>=0) and t1 or t2; t=math.max(t,0.001)^0.5
  return f*t/2+ld/t
end

local function installHooks()
  if pfHooked or not pfNetwork or not pfBullet then return end
  local bulletAccel=(pfPubSettings and pfPubSettings.bulletAcceleration) or V3(0,-workspace.Gravity*0.45,0)
  origSend=pfNetwork.send; origNewBullet=pfBullet.new
  function pfNetwork:send(name,...)
    if name=="newbullets" and CFG.sa_on and saRoll<=CFG.sa_hitpct then
      local pn=saHead<=CFG.sa_headpct and "Head" or "Torso"
      local pos=getTarget(CFG.sa_fov,CFG.sa_predmult,pn)
      if pos then
        local a,data,time,b=...
        if type(data)=="table" and data.bullets and data.firepos then
          local spd=data.bullets[1] and data.bullets[1][1]
          if spd then
            local vel=solveVel(data.firepos,bulletAccel,pos,spd.Magnitude)
            for i=1,#data.bullets do data.bullets[i][1]=vel end
          end
          return origSend(self,name,a,data,time,b)
        end
      end
    end
    return origSend(self,name,...)
  end
  function pfBullet.new(data)
    if CFG.sa_on and data.onplayerhit and saRoll<=CFG.sa_hitpct then
      local pn=saHead<=CFG.sa_headpct and "Head" or "Torso"
      local pos=getTarget(CFG.sa_fov,CFG.sa_predmult,pn)
      if pos and data.position and data.velocity then
        data.velocity=solveVel(data.position,bulletAccel,pos,data.velocity.Magnitude)
      end
    end
    return origNewBullet(data)
  end
  pfHooked=true;
end

local function loadPFModules()
  local sharedEnv=nil; local ok,nils=pcall(getnilinstances)
  if ok and nils then
    for i=1,#nils do
      local inst=nils[i]
      if inst.Name=="ClientLoader" and inst:IsA("LocalScript") then
        local env=getsenv(inst)
        if env and type(env.shared)=="table" and type(env.shared.require)=="function" then sharedEnv=env.shared; break end
      end
    end
  end
  if not sharedEnv then task.delay(3,loadPFModules); return end
  local req=sharedEnv.require
  pcall(function() pfNetwork=req("NetworkClient") end)
  pcall(function() pfBullet=req("BulletObject") end)
  pcall(function() pfPubSettings=req("PublicSettings") end)
  if pfNetwork and pfBullet then installHooks() else task.delay(3,loadPFModules) end
end
