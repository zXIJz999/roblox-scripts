local function tickAimbot(dt)
  if Options.KA_Key:GetState() and LP.Character and LP.Character:FindFirstChild("HumanoidRootPart") then
      local targetChar = getTargetChar(9999)
      if targetChar and targetChar:FindFirstChild("HumanoidRootPart") and targetChar:FindFirstChild("Head") then
          local tHrp = targetChar.HumanoidRootPart
          local tHead = targetChar.Head
          local offset = CFrame.new(0,0,0)
          local dist = CFG.rage_ka_dist
          
          if CFG.rage_ka_pos == "Behind" then offset = CFrame.new(0, 0, dist)
          elseif CFG.rage_ka_pos == "Above" then offset = CFrame.new(0, dist, 0)
          elseif CFG.rage_ka_pos == "Below" then offset = CFrame.new(0, -dist, 0)
          elseif CFG.rage_ka_pos == "Front" then offset = CFrame.new(0, 0, -dist)
          end
          
          local tpPos = (tHrp.CFrame * offset).Position
          LP.Character.HumanoidRootPart.CFrame = CFrame.new(tpPos, tHead.Position)
          Camera.CFrame = CFrame.new(Camera.CFrame.Position, tHead.Position)
          mouse:Button1Click()
          return
      end
  end

  if Options.StrafeKey:GetState() and LP.Character and LP.Character:FindFirstChild("HumanoidRootPart") then
      local targetChar = getTargetChar(CFG.ab_fov)
      if targetChar and targetChar:FindFirstChild("HumanoidRootPart") and targetChar:FindFirstChild("Head") then
          strafeAngle = strafeAngle + CFG.rage_strafe_speed * dt
          local tHrp = targetChar.HumanoidRootPart
          local offset = Vector3.new(math.cos(strafeAngle) * CFG.rage_strafe_range, math.sin(strafeAngle * 1.5) * (CFG.rage_strafe_range/3), math.sin(strafeAngle) * CFG.rage_strafe_range)
          
          LP.Character.HumanoidRootPart.CFrame = CFrame.new(tHrp.Position + offset, targetChar.Head.Position)
          Camera.CFrame = CFrame.new(Camera.CFrame.Position, targetChar.Head.Position)
          if CFG.rage_auto_shoot then mouse:Button1Click() end
          return
      end
  end

  if not CFG.ab_on then return end
  if CFG.ab_hold_key and not UIS:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then return end
  if not LP.Character then return end
  
  local pos = getTarget(CFG.ab_fov, CFG.ab_predmult, CFG.ab_part)
  if not pos then return end
  
  local targetCF = CFrame.new(Camera.CFrame.Position, pos)
  if CFG.ab_hard_lock then Camera.CFrame = targetCF; return end
  
  local maxRad = math.rad(CFG.ab_max_speed) * dt
  local angle = math.acos(mcl(Camera.CFrame.LookVector:Dot(targetCF.LookVector), -1, 1))
  local lerpT = CFG.ab_smooth
  if angle > maxRad then lerpT = mcl(maxRad / angle, 0, lerpT) end
  Camera.CFrame = Camera.CFrame:Lerp(targetCF, lerpT)
end

