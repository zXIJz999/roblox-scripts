-- NO RECOIL
-- Only active while LMB held, cancels 100% upward camera kick
-- ═══════════════════════════════════════════════════════════
local lastCamCF=nil
RunService.RenderStepped:Connect(function()
    if not CFG.no_recoil_on then lastCamCF=Camera.CFrame; return end
    if lastCamCF and UIS:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) then
        local prevLook=lastCamCF.LookVector; local curLook=Camera.CFrame.LookVector
        local prevPitch=math.atan2(prevLook.Y,Vector2.new(prevLook.X,prevLook.Z).Magnitude)
        local curPitch =math.atan2(curLook.Y, Vector2.new(curLook.X, curLook.Z).Magnitude)
        local delta=curPitch-prevPitch
        if delta>0.002 then
            Camera.CFrame=Camera.CFrame*CFrame.fromEulerAnglesYXZ(-delta,0,0)
        end
    end
    lastCamCF=Camera.CFrame
end)

