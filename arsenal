-- MATH / UTIL ALIASES
-- ═══════════════════════════════════════════════════════════
local V3, V2, CF = Vector3.new, Vector2.new, CFrame.new
local mfl, mcl = math.floor, math.clamp
local mra, mco, msi = math.random, math.cos, math.sin
local huge = math.huge

local function isVisible(part)
  local origin = Camera.CFrame.Position
  local dir    = (part.Position - origin)
  local ray    = Ray.new(origin, dir)
  local hit    = workspace:FindPartOnRayWithIgnoreList(ray,{LP.Character,Camera},false,true)
  return not hit or Players:GetPlayerFromCharacter(hit.Parent)~=nil or Players:GetPlayerFromCharacter(hit.Parent.Parent)~=nil
end

local function rot2(x,y,a)
  local c,s=mco(a),msi(a); return x*c-y*s, x*s+y*c
end
local function sv(x,y,cx,cy) return V2(cx+x,cy+y) end

local function newLine(thick,col)
  local l=Drawing.new("Line")
  l.Thickness=thick or 1; l.Color=col or Color3.new(1,1,1)
  l.Visible=false; l.ZIndex=5; return l
end

local function newText(size,col)
  local t=Drawing.new("Text")
  t.Size=size or 13; t.Color=col or Color3.new(1,1,1)
  t.Visible=false; t.Outline=true; t.ZIndex=6; return t
end

