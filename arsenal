-- ═══════════════════════════════════════════════════════════
local strafeAngle=0
local function isPosSafe(pos)
    if pos.Y<CFG.rage_min_y then return false end
    return workspace:Raycast(pos+V3(0,50,0),V3(0,-100,0))~=nil
end
local function getStrafePos(tHrpPos)
    local r=CFG.rage_strafe_range
    local offset=V3(mco(strafeAngle)*r,math.abs(msi(strafeAngle*1.5))*(r*0.4),msi(strafeAngle)*r)
    local newPos=tHrpPos+offset
    local gr=workspace:Raycast(newPos+V3(0,10,0),V3(0,-20,0))
    if gr then newPos=V3(newPos.X,math.max(newPos.Y,gr.Position.Y+3),newPos.Z) end
    return newPos
end

