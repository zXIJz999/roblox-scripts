  local hit = workspace:FindPartOnRayWithIgnoreList(ray,{LP.Character,Camera},false,true)
  return not hit or Players:GetPlayerFromCharacter(hit.Parent)~=nil or Players:GetPlayerFromCharacter(hit.Parent.Parent)~=nil
end

