            head.CFrame = hrp.CFrame * CFrame.fromEulerAnglesYXZ(0, offset, 0) * headOff
        elseif CFG.aa_mode == "static" then
            head.CFrame = hrp.CFrame * CFrame.fromEulerAnglesYXZ(0, math.rad(CFG.aa_static_yaw), 0) * headOff
        end
    end)
end

