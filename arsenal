-- TARGET SELECTION
-- ═══════════════════════════════════════════════════════════
local function getTarget(fovR,predMult,partName)
  local vp=Camera.ViewportSize
  local center=V2(vp.X*0.5,vp.Y*0.5)
  local myTeam=LP.Team
  local best=nil; local bestScore=huge
  for _,plr in ipairs(Players:GetPlayers()) do
    if plr==LP then continue end
    if CFG.ab_team and plr.Team==myTeam then continue end
    local char=plr.Character
    if not char then continue end
    local hum=char:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health<=0 then continue end
    local part=char:FindFirstChild(partName or CFG.ab_part) or char:FindFirstChild("HumanoidRootPart")
    if not part then continue end
    if CFG.ab_visible and not isVisible(part) then continue end
    local pos=part.Position
    if predMult and predMult>0 and CFG.ab_predict then
      local root=char:FindFirstChild("HumanoidRootPart")
      if root then
        local vel=root.AssemblyLinearVelocity
        pos=pos+V3(vel.X*predMult,vel.Y*predMult,vel.Z*predMult)
      end
    end
    local sp,on=Camera:WorldToViewportPoint(pos)
    if not on or sp.Z<0 then continue end
    local screenDist=(V2(sp.X,sp.Y)-center).Magnitude
    if screenDist>fovR then continue end
    local score
    local pri=CFG.ab_priority
    if pri=="hp" then score=hum.Health
    elseif pri=="distance" then score=(part.Position-Camera.CFrame.Position).Magnitude
    elseif pri=="manual" and CFG.ab_pinned then score=(plr==CFG.ab_pinned) and -huge or screenDist
    else score=screenDist end
    if score<bestScore then bestScore=score; best=pos end
  end
  return best
end

