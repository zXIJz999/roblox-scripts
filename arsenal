local function refreshPlayerDropdown()
    local names = {'None'}
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LP then table.insert(names, p.Name) end
    end
    Options.PlayerSelect:SetValues(names)
end
task.spawn(function()
    refreshPlayerDropdown()
    Players.PlayerAdded:Connect(refreshPlayerDropdown)
    Players.PlayerRemoving:Connect(refreshPlayerDropdown)
end)

local SelectedPlayer = nil
Options.PlayerSelect:OnChanged(function()
    local val = Options.PlayerSelect.Value
    SelectedPlayer = (val and val ~= 'None') and Players:FindFirstChild(val) or nil
end)

GB.PlrAct:AddButton('Pin Target (Aimbot)', function()
    if SelectedPlayer then
        CFG.ab_pinned = SelectedPlayer; CFG.ab_priority = "manual"
        Library:Notify("Pinned " .. SelectedPlayer.Name)
    end
end)
GB.PlrAct:AddButton('Teleport To Player', function()
    if SelectedPlayer and SelectedPlayer.Character and SelectedPlayer.Character:FindFirstChild("HumanoidRootPart")
        and LP.Character and LP.Character:FindFirstChild("HumanoidRootPart") then
        LP.Character.HumanoidRootPart.CFrame = SelectedPlayer.Character.HumanoidRootPart.CFrame * CFrame.new(0,0,4)
    end
end)
GB.PlrAct:AddDropdown('PlayerPriority', {Values={'Normal','High','Ignore'}, Default=1, Text='Aim Priority'})
Options.PlayerPriority:OnChanged(function()
    local val = Options.PlayerPriority.Value
