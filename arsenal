-- ESP POOL (UPDATED HP BAR)
-- ═══════════════════════════════════════════════════════════
local BONE_PAIRS={
  {"Head","UpperTorso"},{"UpperTorso","LowerTorso"},
  {"UpperTorso","LeftUpperArm"},{"LeftUpperArm","LeftLowerArm"},{"LeftLowerArm","LeftHand"},
  {"UpperTorso","RightUpperArm"},{"RightUpperArm","RightLowerArm"},{"RightLowerArm","RightHand"},
  {"LowerTorso","LeftUpperLeg"},{"LeftUpperLeg","LeftLowerLeg"},{"LeftLowerLeg","LeftFoot"},
  {"LowerTorso","RightUpperLeg"},{"RightUpperLeg","RightLowerLeg"},{"RightLowerLeg","RightFoot"},
}

local espPool={}
local function getESPEntry(plr)
  if espPool[plr] then return espPool[plr] end
  local e={
    lines={}, nameText=newText(12,CFG.esp_name_col),
    hpText=newText(11,CFG.esp_hp_col), distText=newText(10,Color3.fromRGB(160,120,220)),
    snapLine=newLine(CFG.snap_thick,CFG.snap_col), skelLines={}, selBoxes={},
    hpBarBg=newLine(3, Color3.new(0,0,0)), hpBarFill=newLine(1, Color3.new(0,1,0))
  }
  for i=1,4 do e.lines[i]=newLine(CFG.esp_thick,CFG.esp_box_col) end
  for i=1,#BONE_PAIRS do e.skelLines[i]=newLine(CFG.esp_skel_thick,CFG.esp_skel_col) end
  espPool[plr]=e; return e
