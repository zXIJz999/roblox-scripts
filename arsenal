local function getCharBox(char)
    local root = char:FindFirstChild("HumanoidRootPart")
    local head = char:FindFirstChild("Head")
    if not root or not head then return nil end
    local hum = char:FindFirstChildOfClass("Humanoid")
    local hrp2d, onScreen = Camera:WorldToViewportPoint(root.Position)
    if not onScreen or hrp2d.Z < 0 then return nil end
    local topPos = head.Position + V3(0, head.Size.Y * 0.5, 0)
    local botPos = root.Position - V3(0, 3, 0)
    local top2d, onT = Camera:WorldToViewportPoint(topPos)
    local bot2d, onB = Camera:WorldToViewportPoint(botPos)
    if not onT or not onB or top2d.Z < 0 or bot2d.Z < 0 then return nil end
    local boxH = math.abs(bot2d.Y - top2d.Y)
    if boxH < 4 then return nil end
    local sL2d = Camera:WorldToViewportPoint(root.Position - root.CFrame.RightVector * 1.5)
    local sR2d = Camera:WorldToViewportPoint(root.Position + root.CFrame.RightVector * 1.5)
    local boxW = math.max(math.abs(sR2d.X - sL2d.X), boxH * 0.4)
    local hp    = hum and hum.Health or 0
    local maxhp = hum and hum.MaxHealth or 100
    local cx    = hrp2d.X
    return {
        tl=V2(cx-boxW*0.5, top2d.Y), tr=V2(cx+boxW*0.5, top2d.Y),
        bl=V2(cx-boxW*0.5, bot2d.Y), br=V2(cx+boxW*0.5, bot2d.Y),
        cx=cx, hpPct=mcl(hp/math.max(maxhp,1),0,1),
        hp=mfl(hp), bot=V2(cx, bot2d.Y), dist=mfl(hrp2d.Z),
    }
end

local function drawSkeleton(char, skelLines)
    for i=1,#BONE_PAIRS do skelLines[i].Visible=false end
    if not CFG.esp_skel_on then return end
    for i=1,#BONE_PAIRS do
        local pair = BONE_PAIRS[i]
        local pA = char:FindFirstChild(pair[1])
        local pB = char:FindFirstChild(pair[2])
        if pA and pB then
            local a2,onA = Camera:WorldToViewportPoint(pA.Position)
            local b2,onB = Camera:WorldToViewportPoint(pB.Position)
            if onA and onB and a2.Z > 0 and b2.Z > 0 then
                local sl = skelLines[i]
                sl.From=V2(a2.X,a2.Y); sl.To=V2(b2.X,b2.Y)
                sl.Color=CFG.esp_skel_col; sl.Visible=true
            end
        end
    end
end

-- ═══════════════════════════════════════════════════════════
-- TARGET SELECTION
-- ═══════════════════════════════════════════════════════════
local function getTargetChar(fovR)
    local center = V2(Camera.ViewportSize.X*0.5, Camera.ViewportSize.Y*0.5)
    local best = nil; local bestDist = huge
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr == LP then continue end
        if CFG.sa_team and plr.Team ~= nil and plr.Team == LP.Team then continue end
        local char = plr.Character
        local hum  = char and char:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then continue end
        local root = char:FindFirstChild("HumanoidRootPart")
        if not root then continue end
        local sp, on = Camera:WorldToViewportPoint(root.Position)
        if not on or sp.Z < 0 then continue end
        local dist = (V2(sp.X, sp.Y) - center).Magnitude
        if dist < fovR and dist < bestDist then bestDist = dist; best = char end
    end
    return best
end

local function getTarget(fovR, predMult, partName)
    local center = V2(Camera.ViewportSize.X*0.5, Camera.ViewportSize.Y*0.5)
    local best = nil; local bestScore = huge
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr == LP then continue end
        if CFG.ab_team and plr.Team ~= nil and plr.Team == LP.Team then continue end
        local prioState = CFG.player_priorities[plr.Name] or "Normal"
        if prioState == "Ignore" then continue end
        local char = plr.Character
        local hum  = char and char:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then continue end
        local part = char:FindFirstChild(partName) or char:FindFirstChild("HumanoidRootPart")
        if not part then continue end
        if CFG.ab_visible and not isVisible(part) then continue end
        local pos = part.Position
        if predMult and predMult > 0 and CFG.ab_predict then
            local root = char:FindFirstChild("HumanoidRootPart")
            if root then
                local vel = root.AssemblyLinearVelocity
                if vel.Magnitude > 150 then vel = vel.Unit * 150 end
                pos = pos + vel * predMult
            end
        end
        local sp, on = Camera:WorldToViewportPoint(pos)
        if not on or sp.Z < 0 then continue end
        local dist = (V2(sp.X,sp.Y) - center).Magnitude
        if dist > fovR then continue end
        local score = dist
        if CFG.ab_priority == "hp" then score = hum.Health
        elseif CFG.ab_priority == "distance" then score = (part.Position - Camera.CFrame.Position).Magnitude
        elseif CFG.ab_priority == "manual" and CFG.ab_pinned == plr then score = -huge end
        if prioState == "High" then score = score - 5000 end
        if score < bestScore then bestScore = score; best = pos end
    end
    return best
end

local function getSafestTarget()
    local bestTarget = nil; local highestScore = -huge
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr == LP then continue end
        if CFG.ab_team and plr.Team ~= nil and plr.Team == LP.Team then continue end
        local prioState = CFG.player_priorities[plr.Name] or "Normal"
        if prioState == "Ignore" then continue end
        local char = plr.Character
        local hum  = char and char:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then continue end
        local root = char:FindFirstChild("HumanoidRootPart")
        if not root then continue end
        if root.Position.Y < CFG.rage_min_y then continue end
        local distToMe = (Camera.CFrame.Position - root.Position).Magnitude
        if distToMe > CFG.rage_max_range then continue end
        local score = 0
        if prioState == "High" then score = score + 10000 end
        local nearestAllyDist = huge
        for _, op in ipairs(Players:GetPlayers()) do
            if op ~= plr and op ~= LP and op.Team == plr.Team then
                local oc = op.Character
                if oc and oc:FindFirstChild("HumanoidRootPart") then
                    local d = (root.Position - oc.HumanoidRootPart.Position).Magnitude
                    if d < nearestAllyDist then nearestAllyDist = d end
                end
            end
        end
        score = score + (nearestAllyDist ~= huge and nearestAllyDist or 5000)
        if score > highestScore then highestScore = score; bestTarget = plr end
    end
    return bestTarget
end

