-- ═══════════════════════════════════════════════════════════
local function updateChams()
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr == LP then continue end
        local char = plr.Character
        if not char then continue end
        local isTeam = plr.Team ~= nil and plr.Team == LP.Team
        local col = isTeam and CFG.chams_team_col or CFG.chams_enemy_col
        if CFG.chams_on then
            local hl = char:FindFirstChild("zxijz_chams")
            if not hl then
                hl = Instance.new("Highlight"); hl.Name = "zxijz_chams"; hl.Parent = char
            end
            hl.FillColor = col
            hl.FillTransparency = CFG.chams_solid and 0 or CFG.chams_transparency
            hl.OutlineColor = CFG.chams_outline_col
            hl.OutlineTransparency = CFG.chams_solid and 1 or 0
            hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
            if CFG.chams_material ~= "Highlight Only" then
                for _, p in ipairs(char:GetDescendants()) do
                    if (p:IsA("BasePart") or p:IsA("MeshPart")) and p.Name ~= "HumanoidRootPart" then
                        pcall(function()
                            p.Material = Enum.Material[CFG.chams_material]
                            p.Color = col
                        end)
                    end
                end
            end
        else
            local hl = char:FindFirstChild("zxijz_chams")
            if hl then hl:Destroy() end
        end
    end
    -- viewmodel
    local arms = Camera:FindFirstChild("Arms")
    if arms then
        local vHl = arms:FindFirstChild("zxijz_vm")
        if CFG.viewmodel_chams then
            if not vHl then vHl = Instance.new("Highlight", arms); vHl.Name = "zxijz_vm" end
            vHl.FillColor = CFG.viewmodel_col
            vHl.FillTransparency = 0; vHl.OutlineTransparency = 1
            for _, p in ipairs(arms:GetDescendants()) do
                if p:IsA("BasePart") or p:IsA("MeshPart") then
                    pcall(function() p.Material = Enum.Material[CFG.viewmodel_material] end)
                end
            end
        else
            if vHl then vHl:Destroy() end
        end
    end
end

task.spawn(function()
    while task.wait(0.5) do pcall(updateChams) end
end)

