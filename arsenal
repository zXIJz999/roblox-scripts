      local box=getCharBox(char)
      if box then
        local tl,tr,bl,br=box.tl,box.tr,box.bl,box.br
        e.lines[1].From=tl; e.lines[1].To=tr
        e.lines[2].From=bl; e.lines[2].To=br
        e.lines[3].From=tl; e.lines[3].To=bl
        e.lines[4].From=tr; e.lines[4].To=br
        local bc=CFG.esp_box_col
        for j=1,4 do e.lines[j].Color=bc; e.lines[j].Visible=true end
        e.nameText.Text=plr.DisplayName
        e.nameText.Position=V2(box.cx-30,tl.Y-16)
        e.nameText.Color=CFG.esp_name_col; e.nameText.Visible=true
        
        -- HP Text
        if CFG.esp_hp_text_on then
            e.hpText.Text=tostring(box.hp).." HP"
            e.hpText.Position=V2(box.cx-14,tl.Y-28)
            e.hpText.Color=Color3.fromHSV(box.hpPct*0.33,1,1); e.hpText.Visible=true
        else e.hpText.Visible=false end
        
        -- HP Bar
        if CFG.esp_hp_bar_on then
            local barHeight = br.Y - tr.Y
            local barX = tr.X + 4
            e.hpBarBg.From = V2(barX, tr.Y)
            e.hpBarBg.To = V2(barX, br.Y)
            e.hpBarBg.Visible = true
            
            local hpOffset = barHeight * (1 - box.hpPct)
            e.hpBarFill.From = V2(barX, br.Y)
            e.hpBarFill.To = V2(barX, tr.Y + hpOffset)
            e.hpBarFill.Color = Color3.fromHSV(box.hpPct * 0.33, 1, 1)
            e.hpBarFill.Visible = true
        else e.hpBarBg.Visible = false; e.hpBarFill.Visible = false end

        -- Distance Label (Moved to Bottom)
        if CFG.esp_dist_on then
          e.distText.Text=box.dist.." st"
          e.distText.Position=V2(box.cx-10, br.Y + 2)
          e.distText.Visible=true
        else e.distText.Visible=false end
      else
        hideESP(e)
      end
    else
      hideESP(e)
    end

    drawSkeleton(char,e.skelLines)

    if CFG.snap_on and root then
      local sp2,on2=Camera:WorldToViewportPoint(root.Position)
      if on2 and sp2.Z>0 then
        e.snapLine.From=snapOrigin; e.snapLine.To=V2(sp2.X,sp2.Y)
        e.snapLine.Color=CFG.snap_col; e.snapLine.Visible=true
      else e.snapLine.Visible=false end
    else e.snapLine.Visible=false end
  end

  for plr in pairs(espPool) do
    if not plr.Parent then cleanESP(plr) end
  end

  fovCircle.Position=V2(cx,cy)
  fovCircle.Radius=CFG.ab_fov
  fovCircle.Visible=CFG.ab_showfov

  tickAimbot(dt)
  tickTriggerbot()

  chAngle=chAngle+CFG.ch_rot_speed*dt
  chHue=(chHue+CFG.ch_hue_speed*dt)%1
  local col=Color3.fromHSV(chHue,1,1)
  local S=CFG.ch_size
  local li=1
  for _,seg in ipairs(SW_SEGS) do
    local ax,ay=rot2(seg[1]*S,seg[2]*S,chAngle)
    local bx,by=rot2(seg[3]*S,seg[4]*S,chAngle)
    CH_LINES[li].From=sv(ax,ay,cx,cy); CH_LINES[li].To=sv(bx,by,cx,cy)
    CH_LINES[li].Color=col; CH_LINES[li].Visible=CFG.ch_on; li=li+1
    local lax,lay=rot2(seg[5]*S,seg[6]*S,chAngle)
    local lbx,lby=rot2(seg[7]*S,seg[8]*S,chAngle)
    CH_LINES[li].From=sv(lax,lay,cx,cy); CH_LINES[li].To=sv(lbx,lby,cx,cy)
    CH_LINES[li].Color=col; CH_LINES[li].Visible=CFG.ch_on; li=li+1
  end
  
  updateKeybindsUI()
end)

-- ═══════════════════════════════════════════════════════════
-- KEYBINDS
-- ═══════════════════════════════════════════════════════════
UIS.InputBegan:Connect(function(inp,gp)
  if gp then return end
  local kc=inp.KeyCode
  if kc==Enum.KeyCode.RightShift then
    Library:Toggle()
  elseif kc==Enum.KeyCode.F then
    CFG.fly_on=not CFG.fly_on
  elseif kc==Enum.KeyCode.V then
    CFG.nc_on=not CFG.nc_on
  elseif kc==Enum.KeyCode.H then
    CFG.aa_on=not CFG.aa_on
  elseif kc==Enum.KeyCode.CapsLock then
    CFG.tb_on=not CFG.tb_on
  end
end)

