local repo='https://raw.githubusercontent.com/violin-suzutsuki/LinoriaLib/main/'
local function loadRemote(path)
    local ok,body=pcall(function() return game:HttpGet(repo..path,true) end)
    if not ok or type(body)~='string' then dbgErr("LOADER","loadRemote failed: "..path); return nil end
    local fn=loadstring(body); if not fn then return nil end
    local s,result=pcall(fn); return s and result or nil
end

