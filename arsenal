local ncConn=nil
local function noclipStart()
    if ncConn then return end
    ncConn=RunService.Stepped:Connect(function()
        local char=LP.Character; if not char then return end
        for _,part in ipairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide=(CFG.nc_floor_safe and part.Name=="HumanoidRootPart")
            end
        end
    end)
end
local function noclipStop()
    if ncConn then ncConn:Disconnect(); ncConn=nil end
    local char=LP.Character; if not char then return end
    for _,part in ipairs(char:GetDescendants()) do if part:IsA("BasePart") then part.CanCollide=true end end
end

