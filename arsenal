local tbLastFire=0

local function tickTriggerbot()
  if not CFG.tb_on then return end
  local now=tick()
  if (now-tbLastFire)<(CFG.tb_delay/1000) then return end
  
  local ray = Camera:ScreenPointToRay(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
  local hit = workspace:FindPartOnRayWithIgnoreList(Ray.new(ray.Origin, ray.Direction * 1000), {LP.Character})
  
  if hit and hit.Parent then
      local plr = Players:GetPlayerFromCharacter(hit.Parent) or Players:GetPlayerFromCharacter(hit.Parent.Parent)
      if plr and plr ~= LP then
          if CFG.tb_team and plr.Team == LP.Team then return end
          mouse:Button1Click()
          tbLastFire = now
      end
  end
end

