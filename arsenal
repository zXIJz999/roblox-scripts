-- TRIGGERBOT — FIXED
-- Was using FindPartOnRayWithIgnoreList (deprecated, unreliable).
-- Now uses workspace:Raycast with proper exclude filter.
-- ═══════════════════════════════════════════════════════════
local tbLastFire=0
local function tickTriggerbot()
    if not CFG.tb_on then return end
    local now=tick()
    if (now-tbLastFire)<(CFG.tb_delay/1000) then return end

    -- Build exclude list: our own character + all team members if team check on
    local excludes={Camera}
    if LP.Character then table.insert(excludes,LP.Character) end
    if CFG.tb_team then
        for _,plr in ipairs(Players:GetPlayers()) do
            if plr~=LP and plr.Team~=nil and plr.Team==LP.Team and plr.Character then
                table.insert(excludes,plr.Character)
            end
        end
    end

    local params=RaycastParams.new()
    params.FilterDescendantsInstances=excludes
    params.FilterType=Enum.RaycastFilterType.Exclude

    local vp=Camera.ViewportSize
    local ray=Camera:ScreenPointToRay(vp.X/2,vp.Y/2)
    local result=workspace:Raycast(ray.Origin,ray.Direction*1000,params)

    if result and result.Instance then
        local inst=result.Instance
        local plr=Players:GetPlayerFromCharacter(inst.Parent)
            or Players:GetPlayerFromCharacter(inst.Parent.Parent)
        if plr and plr~=LP then
            -- Extra team check in case they're not filtered above
            if CFG.tb_team and plr.Team~=nil and plr.Team==LP.Team then return end
            task.spawn(doClick)
            tbLastFire=now
        end
    end
end

