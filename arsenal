GB.CfgSave:AddButton('Save Config', function()
    if not writefile then return end
    initializeFolders()
    local t = {}
    for k, v in pairs(CFG) do
        if type(v) ~= "userdata" and type(v) ~= "function" then t[k] = v end
    end
    pcall(function() writefile(cfgFilePath, HttpService:JSONEncode(t)) end)
    Library:Notify("Config Saved!")
end)

GB.CfgSave:AddButton('Load Config', function()
    if not readfile then return end
    pcall(function()
        local raw = readfile(cfgFilePath)
        local t = HttpService:JSONDecode(raw)
        for k,v in pairs(t) do
            if CFG[k] ~= nil and type(CFG[k]) == type(v) then CFG[k] = v end
        end
    end)
    Library:Notify("Config Loaded!")
end)

GB.CfgSave:AddToggle('auto_load', {Text='Auto-Load Config on Boot', Default=false})
Toggles.auto_load:OnChanged(function()
    if writefile then
        initializeFolders()
        pcall(function() writefile(autoLoadPath, tostring(Toggles.auto_load.Value)) end)
    end
end)

if readfile then
    pcall(function()
        if readfile(autoLoadPath) == "true" then
            local raw = readfile(cfgFilePath)
            local t = HttpService:JSONDecode(raw)
            for k,v in pairs(t) do
                if CFG[k] ~= nil and type(CFG[k]) == type(v) then CFG[k] = v end
            end
            Toggles.auto_load:SetValue(true)
            Library:Notify("Auto-Loaded Config!")
        end
    end)
end

