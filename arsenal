-- TRIGGERBOT
-- ═══════════════════════════════════════════════════════════
local tbLastFire = 0
local function tickTriggerbot()
    if not CFG.tb_on then return end
    local now = tick()
    if (now - tbLastFire) < (CFG.tb_delay/1000) then return end
    local params = RaycastParams.new()
    params.FilterDescendantsInstances = {LP.Character, Camera}
    params.FilterType = Enum.RaycastFilterType.Exclude
    local ray = Camera:ScreenPointToRay(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
    local result = workspace:Raycast(ray.Origin, ray.Direction * 9999, params)
    if result then
        local plr = Players:GetPlayerFromCharacter(result.Instance.Parent)
            or Players:GetPlayerFromCharacter(result.Instance.Parent.Parent)
        if plr and plr ~= LP then
            if CFG.tb_team and plr.Team ~= nil and plr.Team == LP.Team then return end
            doShoot(); tbLastFire = now
        end
    end
end

