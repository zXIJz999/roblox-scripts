-- Fast single click — used by rapid fire and strafe auto-shoot
-- Picks the best available method
local function doClick()
    if mouse1click then
        pcall(mouse1click)
    elseif mouse1press then
        pcall(mouse1press)
        task.wait(0.013)
        pcall(mouse1release)
    else
        pcall(function() mouse:Button1Down() end)
        task.wait(0.013)
        pcall(function() mouse:Button1Up() end)
    end
end

-- ═══════════════════════════════════════════════════════════
-- SPAWN PROTECTION CHECK
-- Returns true if player is currently spawn-protected / just spawned
-- Arsenal uses a Highlight on the character named after protection,
-- or we just track spawn time ourselves
-- ═══════════════════════════════════════════════════════════
local spawnTimes = {}   -- [player] = tick() when they last spawned
local SPAWN_GRACE = 3.0 -- seconds of grace after spawning

Players.PlayerAdded:Connect(function(plr)
    plr.CharacterAdded:Connect(function()
        spawnTimes[plr] = tick()
    end)
end)
for _, plr in ipairs(Players:GetPlayers()) do
    plr.CharacterAdded:Connect(function()
        spawnTimes[plr] = tick()
    end)
    if plr.Character then spawnTimes[plr] = tick() - SPAWN_GRACE - 1 end
end
Players.PlayerRemoving:Connect(function(plr)
    spawnTimes[plr] = nil
end)

local function isSpawnProtected(plr)
    -- Time-based check
    local t = spawnTimes[plr]
    if t and (tick() - t) < SPAWN_GRACE then return true end
    -- Highlight-based check (Arsenal sometimes adds one)
    if plr.Character then
        for _, d in ipairs(plr.Character:GetDescendants()) do
            if d:IsA("Highlight") and (
                d.Name:lower():find("spawn") or
                d.Name:lower():find("protect") or
                d.Name:lower():find("invincib") or
                d.Name:lower():find("immune")
            ) then return true end
        end
        -- Check if humanoid is invincible (MaxHealth locked trick Arsenal uses)
        local hum = plr.Character:FindFirstChildOfClass("Humanoid")
        if hum and hum.Health == hum.MaxHealth and hum.MaxHealth > 100 then return true end
    end
    return false
end

